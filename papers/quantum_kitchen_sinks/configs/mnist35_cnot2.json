{
    "description": "QKS on (3,5)-MNIST, 2-qubit CNOT ansatz (Fig. 2a), tile encoding.",
    "experiment": "mnist35",
    "seeds": [42, 43, 44],
    "dataset": {
        "name": "mnist35",
        "n_train": 4000,
        "n_test": 1000,
        "standardize": true
    },
    "qks": {
        "backend": "gate",
        "circuit": "cnot2",
        "n_qubits": 2,
        "encoding": "tile",
        "n_episodes": 5000,
        "sigma": 0.1,
        "shots_per_episode": 1,
        "n_layers": 1
    },
    "classifier": {
        "kind": "logistic_regression",
        "C": 1.0,
        "max_iter": 4000
    }
}
