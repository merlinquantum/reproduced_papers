{
    "description": "Logistic regression baseline on raw 2-D picture frames features.",
    "experiment": "picture_frames_baseline",
    "seeds": [42, 43, 44],
    "dataset": {
        "name": "picture_frames",
        "n_train": 1600,
        "n_test": 400,
        "inner_radius": 0.4,
        "outer_radius": 0.7,
        "noise": 0.02
    },
    "qks": {
        "backend": "none",
        "circuit": "cnot2",
        "n_qubits": 2,
        "encoding": "split",
        "n_episodes": 1,
        "sigma": 1.0,
        "shots_per_episode": 1,
        "n_layers": 1
    },
    "classifier": {
        "kind": "logistic_regression",
        "C": 1.0,
        "max_iter": 4000
    }
}
