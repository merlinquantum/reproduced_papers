{
    "description": "Photonic MerLin QKS on (3,5)-MNIST with larger Hilbert subspace (8 modes, 3 photons).",
    "experiment": "mnist35_merlin",
    "seeds": [42, 43, 44],
    "dataset": {
        "name": "mnist35",
        "n_train": 4000,
        "n_test": 1000,
        "standardize": true
    },
    "qks": {
        "backend": "photonic_merlin",
        "n_modes": 8,
        "n_photons": 3,
        "encoding": "tile",
        "n_episodes": 1000,
        "sigma": 0.05,
        "shots_per_episode": 1,
        "n_layers": 1,
        "input_modes": [0, 1, 2],
        "angle_scale": 1.0
    },
    "classifier": {
        "kind": "logistic_regression",
        "C": 1.0,
        "max_iter": 4000
    }
}