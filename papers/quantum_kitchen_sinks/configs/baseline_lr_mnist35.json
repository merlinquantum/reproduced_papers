{
    "description": "Logistic regression baseline on raw (3,5)-MNIST pixels.",
    "experiment": "mnist35_baseline",
    "seeds": [42],
    "dataset": {
        "name": "mnist35",
        "n_train": 4000,
        "n_test": 1000,
        "standardize": true
    },
    "qks": {
        "backend": "none",
        "circuit": "cnot1",
        "n_qubits": 1,
        "encoding": "tile",
        "n_episodes": 1,
        "sigma": 0.05,
        "shots_per_episode": 1,
        "n_layers": 1
    },
    "classifier": {
        "kind": "logistic_regression",
        "C": 1.0,
        "max_iter": 4000
    }
}
