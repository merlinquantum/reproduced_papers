{
    "description": "Photonic MerLin QKS adaptation on picture frames.",
    "experiment": "picture_frames_merlin",
    "seeds": [42, 43, 44],
    "dataset": {
        "name": "picture_frames",
        "n_train": 800,
        "n_test": 200,
        "inner_radius": 0.4,
        "outer_radius": 0.7,
        "noise": 0.02
    },
    "qks": {
        "backend": "photonic_merlin",
        "n_modes": 4,
        "n_photons": 2,
        "encoding": "split",
        "n_episodes": 2000,
        "sigma": 3.0,
        "shots_per_episode": 1,
        "n_layers": 1,
        "input_modes": [0, 1],
        "angle_scale": 1.0
    },
    "classifier": {
        "kind": "logistic_regression",
        "C": 1.0,
        "max_iter": 4000
    }
}
