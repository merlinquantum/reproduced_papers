{
  "description": "Default Photonic QGAN reproduction config (smoke mode).",
  "seed": 0,
  "dtype": "float32",
  "device": "cpu",
  "outdir": "results",
  "logging": { "level": "info", "save_config_snapshot": true },
  "run": {
    "mode": "smoke",
    "write_to_disk": true,
    "runs": 1,
    "progress": true,
    "log_every": 25
  },
  "dataset": {
    "csv_path": "photonic_QGAN/optdigits_csv.csv"
  },
  "model": {
    "image_size": 8,
    "batch_size": 4,
    "lossy": false,
    "use_clements": false,
    "sim": false,
    "remote_token": null
  },
  "training": {
    "digits": {
      "opt_iter_num": 200,
      "optimizer": "adam",
      "spsa_iter_num": 16000,
      "lrD": 0.002,
      "lrG": 0.002,
      "adam_beta1": 0.5,
      "adam_beta2": 0.999,
      "real_label": 0.9,
      "fake_label": 0.0,
      "gen_target": 0.9,
      "d_steps": 1,
      "g_steps": 1
    },
    "ideal": {
      "opt_iter_num": 200,
      "optimizer": "adam",
      "spsa_iter_num": 10500,
      "lrD": 0.0002,
      "lrG": 0.002,
      "adam_beta1": 0.5,
      "adam_beta2": 0.999,
      "real_label": 0.9,
      "fake_label": 0.0,
      "gen_target": 0.9,
      "d_steps": 1,
      "g_steps": 3
    }
  },
  "digits": {
    "arch": ["var", "var", "enc[2]", "var", "var"],
    "noise_dim": 1,
    "input_state": [0, 1, 0, 1, 0],
    "gen_count": 4,
    "pnr": false,
    "digit_start": 1,
    "digit_end": 9,
    "digits": null
  },
  "ideal": {
    "use_default_grid": true,
    "config_grid_path": null,
    "digit": 0
  },
  "hp_study": {
    "setups": ["setup_c"],
    "input_states": ["01010"],
    "digits": [0, 3],
    "ssim_tail": 100,
    "top_k": 10,
    "param_grid": {
      "lrD": [0.0002, 0.0005, 0.001],
      "lrG": [0.001, 0.002, 0.004],
      "adam_beta1": [0.5, 0.7],
      "adam_beta2": [0.99, 0.999],
      "d_steps": [1, 2],
      "g_steps": [1, 2, 3],
      "real_label": [0.9],
      "gen_target": [0.9]
    },
    "halving": {
      "min_resources": 200,
      "max_resources": 1500,
      "factor": 3,
      "cv": 3,
      "random_state": 0
    }
  }
}
