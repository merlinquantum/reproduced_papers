{
  "description": "Ideal-mode SPSA config. Edit ideal.digit, ideal.setup, and ideal.input_state to select the target.",
  "seed": 0,
  "dtype": "float32",
  "device": "cpu",
  "outdir": "results",
  "logging": { "level": "info", "save_config_snapshot": true },
  "run": {
    "mode": "ideal",
    "write_to_disk": true,
    "runs": 3,
    "progress": true,
    "log_every": 100
  },
  "dataset": {
    "csv_path": "photonic_QGAN/optdigits_csv.csv"
  },
  "model": {
    "image_size": 8,
    "batch_size": 4,
    "lossy": false,
    "use_clements": false,
    "sim": false,
    "remote_token": null
  },
  "training": {
    "digits": {
      "opt_iter_num": 1000,
      "optimizer": "adam",
      "spsa_iter_num": 16000,
      "lrD": 0.002,
      "adam_beta1": 0.5,
      "adam_beta2": 0.999,
      "real_label": 0.9,
      "fake_label": 0.0,
      "gen_target": 0.9,
      "d_steps": 1,
      "g_steps": 1
    },
    "ideal": {
      "opt_iter_num": 1500,
      "optimizer": "spsa",
      "spsa_iter_num": 10500,
      "lrD": 0.002,
      "d_optimizer": "sgd",
      "real_label": 1.0,
      "fake_label": 0.0,
      "gen_target": 1.0,
      "d_steps": 1
    }
  },
  "ideal": {
    "digit": 0,
    "setup": "setup_c",
    "input_state": "01010",
    "gen_count": 4,
    "pnr": false
  }
}
