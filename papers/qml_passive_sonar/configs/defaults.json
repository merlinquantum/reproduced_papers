{
  "description": "Smoke config: tiny synthetic data, HQ-CNN with 4 qubits / 2 layers, 2 epochs.",
  "seed": 1337,
  "dtype": "float32",
  "device": "cpu",
  "outdir": "outdir",
  "task": "classification",
  "dataset": {
    "name": "shipear",
    "spectrogram_method": "sav",
    "frame_duration_s": 4.0,
    "frame_overlap": 0.5,
    "target_sr": 4000,
    "image_size": 64,
    "samples_per_class_synthetic": 6,
    "duration_synthetic_s": 8.0,
    "test_fraction": 0.3
  },
  "model": {
    "name": "hqcnn",
    "fc_dim": 64,
    "n_qubits": 4,
    "n_layers": 2,
    "pqc_init": "uniform"
  },
  "training": {
    "epochs": 2,
    "lr": 1e-3,
    "batch_size": 4,
    "weight_decay": 0.0,
    "save_checkpoint": false
  },
  "logging": {"level": "info"}
}
