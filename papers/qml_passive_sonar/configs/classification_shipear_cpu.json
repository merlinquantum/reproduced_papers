{
  "description": "E5 CPU-feasible HQ-CNN on synthetic ShipsEar-like data (reduced).",
  "seed": 42,
  "device": "cpu",
  "outdir": "outdir",
  "task": "classification",
  "dataset": {
    "name": "shipear",
    "spectrogram_method": "sav",
    "frame_duration_s": 8.0,
    "frame_overlap": 0.5,
    "target_sr": 4000,
    "image_size": 64,
    "samples_per_class_synthetic": 12,
    "duration_synthetic_s": 30.0,
    "test_fraction": 0.3
  },
  "model": {
    "name": "hqcnn",
    "fc_dim": 128,
    "n_qubits": 10,
    "n_layers": 4
  },
  "training": {
    "epochs": 20,
    "lr": 5e-4,
    "batch_size": 8,
    "save_checkpoint": false
  },
  "logging": {"level": "info"}
}
