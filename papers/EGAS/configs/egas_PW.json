{
  "description": "EGAS evaluation on PW (reduced-compute: small GPT, fewer iters/splits)",
  "seed": 0, "dtype": "float64", "outdir": "outdir", "device": "cpu",
  "task": "egas_eval",
  "dataset": {"name": "PW", "root": "data", "n_qubits": 8, "n_components": 8},
  "egas": {"seq_len": 28, "n_iters": 120, "n_candidates": 12, "select_k": 6, "gamma": 0.1,
           "lr": 5e-5, "temp_max": 100.0, "temp_min": 0.04, "search_samples": 36,
           "d_model": 32, "n_layers": 1, "n_heads": 2},
  "bias": {"epochs": 120, "batch_samples": 25, "lr": 5e-4},
  "nqe": {"epochs": 60},
  "eval": {"n_train": 400, "n_test": 50, "n_repeats": 8, "top": 4},
  "logging": {"level": "info", "save_config_snapshot": true}
}
