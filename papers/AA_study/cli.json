{
  "description": "CLI schema for the data encoding study",
  "arguments": [
    {
      "flags": ["--exp_to_run"],
      "help": "Which experiment to run between 'BAS', 'FIG1', 'FIG2', 'FIG3', 'FIG4', 'FIG5' and 'FIG7'   (default: 'BAS')",
      "type": "str",
      "default": null,
      "apply": {"kind": "config_path", "path": "exp_to_run"}
    },
    {
      "flags": ["--dataset_to_run"],
      "help": "Which dataset to use in the 'FIG7' experiment. Choose between 'MNIST', 'CIFAR-10','PathMNIST' and 'EuroSAT'  (default: 'MNIST')",
      "type": "str",
      "default": null,
      "apply": {"kind": "config_path", "path": "dataset_to_run"}
    },
    {
      "flags": ["--batch_size"],
      "help": "The number of tests data per batch  (default: 50)",
      "type": "int",
      "default": null,
      "apply": {"kind": "config_path", "path": "batch_size"}
    },
    {
      "flags": ["--num_epochs"],
      "help": "Number of epochs for training (default: 20)",
      "type": "int",
      "default": null,
      "apply": {"kind": "config_path", "path": "num_epochs"}
    },
    {
      "flags": ["--classical_epochs"],
      "help": "Number of epochs for classical CNN training (default: 1)",
      "type": "int",
      "default": null,
      "apply": {"kind": "config_path", "path": "classical_epochs"}
    },
    {
      "flags": ["--lr"],
      "help": "The learning rate of the optimizers (default: 0.01)",
      "type": "float",
      "default": null,
      "apply": {"kind": "config_path", "path": "lr"}
    },
      {
      "flags": ["--num_samples_per_class"],
      "help": "The number of samples to create per class from the synthetic datasets of the paper (default: 2000)",
      "type": "int",
      "default": null,
      "apply": {"kind": "config_path", "path": "lr"}
    },
      {
      "flags": ["--sample_size_per_class_to_test"],
      "help":"The number of samples to get from the dataset for each run analyzed (default: [1,10,100,1000])",
      "type": "str",
      "default": null,
      "apply": {"kind": "config_path", "path": "sample_size_per_class_to_test"}
    },  
    {
      "flags": ["--dont_generate_graph"],
      "help": "Disable weight sharing experiment",
      "type": "bool",
      "default": null,
      "apply": {"kind": "config_path", "path": "dont_generate_graph"}
    }  
  
  ]
}