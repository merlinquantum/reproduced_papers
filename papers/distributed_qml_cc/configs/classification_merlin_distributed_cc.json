{
  "description": "Photonic CC-DQML: two m=8/n=3 chips with classical-feedforward channel (chip 0 soft bit drives a phase on chip 1).",
  "pipeline": "merlin_distributed",
  "seed": 42,
  "seeds": [42, 1, 2],
  "dtype": "float32",
  "outdir": "outdir",
  "dataset": {
    "name": "synthetic_8d",
    "params": {
      "n_dim": 8,
      "n_samples": 2048,
      "n_clusters": 32,
      "samples_per_cluster": 64,
      "sphere_radius": 0.7853981633974483,
      "train_fraction": 0.75,
      "seed": 42
    }
  },
  "model": {
    "name": "MerLinDistributedDQML",
    "params": {
      "scheme": "cc",
      "n_modes_per_chip": 8,
      "n_photons_per_chip": 3,
      "n_features_per_chip": 4,
      "normalize_inputs": false
    }
  },
  "training": {
    "n_iterations": 800,
    "lr": 0.05,
    "batch_size": 256,
    "eval_every": 50
  },
  "logging": {"level": "info", "save_config_snapshot": true}
}
