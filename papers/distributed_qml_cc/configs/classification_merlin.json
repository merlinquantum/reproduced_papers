{
  "description": "MerLin photonic baseline (non-DQML analogue): single 8-mode 3-photon chip with angle encoding on all 8 modes, FirstQuantumLayers-tutorial recipe.",
  "pipeline": "merlin",
  "seed": 42,
  "seeds": [42, 1, 2],
  "dtype": "float32",
  "outdir": "outdir",
  "dataset": {
    "name": "synthetic_8d",
    "params": {
      "n_dim": 8,
      "n_samples": 2048,
      "n_clusters": 32,
      "samples_per_cluster": 64,
      "sphere_radius": 0.7853981633974483,
      "train_fraction": 0.75,
      "seed": 42
    }
  },
  "model": {
    "name": "PhotonicSingleChip",
    "params": {
      "n_modes": 8,
      "n_photons": 3,
      "n_features": 8,
      "angle_scale": 1.0,
      "normalize_inputs": false
    }
  },
  "training": {
    "n_iterations": 800,
    "lr": 0.05,
    "batch_size": 256,
    "eval_every": 50
  },
  "logging": {"level": "info", "save_config_snapshot": true}
}
